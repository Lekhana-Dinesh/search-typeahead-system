{
  "name": "search-typeahead-system",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"node --watch server.js\" \"vite\"",
    "start": "node server.js",
    "build": "vite build",
    "preview": "node server.js --serve-dist",
    "test": "node --test",
    "generate:dataset": "node src/scripts/generateDataset.js",
    "ingest": "node src/scripts/ingestDataset.js",
    "benchmark": "node src/scripts/benchmarkSuggest.js",
    "seed": "node src/scripts/seedDemoData.js 100000",
    "seed:small": "node src/scripts/seedDemoData.js 5000"
  },
  "dependencies": {
    "express": "^4.21.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "vite": "^5.4.12"
  }
}
